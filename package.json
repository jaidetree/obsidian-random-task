{
	"name": "obsidian-random-task-selector",
	"version": "1.0.0",
	"description": "Obsidian plugin: randomly draw a task from the checklist at your cursor and stamp selected-at / completed-at datetimes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:e2e": "wdio run ./wdio.conf.mts"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.6",
		"@eslint/js": "^9.39.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.15.17",
		"@wdio/cli": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"mocha": "^11.7.6",
		"obsidian": "latest",
		"tsx": "^4.22.5",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.9",
		"wdio-obsidian-reporter": "^3.1.1",
		"wdio-obsidian-service": "^3.1.1"
	},
	"dependencies": {
		"unicode-emoji-json": "^0.9.0"
	}
}
